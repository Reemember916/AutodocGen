      "action_suffix": "Check",
      "callee_names": [],
      "comment_desc": "校验 RS422 通信接收报文帧头，确认报文完整性。\n检测帧头1（低8位）和帧头2是否匹配，并计算校验和。",
      "condition_signatures": [
        "buf == NULL || len < 4U",
        "COMM_RS422_HEAD_1 == (buf[0] & 0xFFU)",
        "COMM_RS422_HEAD_2 == (buf[1] & 0xFFU)",
        "l_ii_u16 < (len - 1U)",
        "l_sum_u16 != buf[len - 1U]",
        "l_headErrCnt_u16 > 0U"
      ],
