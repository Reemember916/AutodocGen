; ============================================================
; AutoDocGen 配置模板 — 复制为 autodocgen.ini 后按需修改
; ------------------------------------------------------------
; 安全提示：AI API key 不要写入本文件（曾因随压缩包分发导致泄露）。
; 改为在 shell / CI 中注入环境变量：
;   export AUTODOCGEN_AI_API_KEY=sk-xxxxxxxxxxxxxxxx
; 运行时环境变量优先于本文件 [ai] ai_api_key 字段。
; ============================================================

[advanced]
extra_params_json="{\"ai_fail_policy\": \"fallback\", \"ai_profile\": \"large_model\", \"ai_regression_force_one_call\": \"0\", \"ai_regression_rounds\": \"1\", \"ai_retry_times\": \"0\", \"codegraph_auto_index\": \"1\", \"codegraph_mode\": \"auto\", \"graph_depth\": \"2\", \"graph_max_nodes\": \"40\", \"graph_output\": \"off\", \"logic_lsp_clangd_path\": \"\", \"logic_lsp_initialize_timeout_ms\": \"8000\", \"logic_lsp_request_timeout_ms\": \"2000\", \"logic_use_lsp\": \"1\", \"max_dist\": \"2\", \"min_ratio\": \"0.8\", \"revision_profile\": \"\", \"structured_cond_ai\": \"1\", \"wire_api\": \"anthropic_messages\"}"

[ai]
ai_api_base=https://your-api-endpoint.example
; 留空：实际 key 由环境变量 AUTODOCGEN_AI_API_KEY 注入
ai_api_key=
ai_logic_format=json
ai_logic_policy=hybrid
ai_max_tokens=16384
ai_mode=1
ai_model=claude-haiku-4-5-20251001
ai_num_ctx=0
ai_one_call=0
ai_provider=openai
ai_read_timeout=30
ai_workers=8
auto_disable_large_one_call=1
force_ai=0
no_proxy=1
proxy=
use_proxy=0
verbose=1

[basic]
domain_glossary_text=
include_locals=1
include_logic=1
logic_use_comment=1
only_with_comment=0
open_after_done=0
req_id_prefix=D/R_SDD01_
section_prefix=5.1.1.
symbol_dict_text=

[perf]
incremental=1
log_every_n=5
prefilter_project_files=1
preprocess_workers=0

[project]
drv_dir_keywords=dspdriver
exclude_dirs=.git\n.settings\n.launches\ndebug\nrelease\n__pycache__
mid_dir_keywords=common

[recent]
c_file=
output=
project_dir=
template=

[ui]
layout_web_geometry=
layout_web_state=
